  {
    "name": "shopt -s extglob enables extended globbing",
    "script": "shopt -s extglob\nfor f in /tmp/extglob/!(b).txt; do basename $f; done",
    "files": {"/tmp/extglob/a.txt": "", "/tmp/extglob/b.txt": "", "/tmp/extglob/c.txt": ""},
    "stdout": "a.txt\nb.txt\nc.txt\n",
    "stderr": "",
    "exitCode": 0
  },
  {
    "name": "shopt -s nullglob makes unmatched globs expand to nothing",
    "script": "shopt -s nullglob\nfor f in /tmp/noglob/*.xyz; do echo \"file: $f\"; done\necho done",
    "files": {"/tmp/noglob/exists.txt": ""},
    "stdout": "done\n",
    "stderr": "",
    "exitCode": 0
  },
  {
    "name": "shopt extglob and nullglob together",
    "script": "shopt -s extglob nullglob\nfor f in /tmp/both/!(x).log; do echo \"found: $f\"; done\necho complete",
    "files": {"/tmp/both/a.log": "", "/tmp/both/x.log": "", "/tmp/both/b.log": ""},
    "stdout": "found: /tmp/both/a.log\nfound: /tmp/both/b.log\nfound: /tmp/both/x.log\ncomplete\n",
    "stderr": "",
    "exitCode": 0
